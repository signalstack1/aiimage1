{
  "buildCommand": "pnpm --filter @workspace/signal-saas run build",
  "outputDirectory": "artifacts/signal-saas/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
