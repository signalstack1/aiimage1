{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "installCommand": "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 pnpm install",
  "framework": null,
  "functions": {
    "api/[...path].ts": {
      "runtime": "@vercel/node@3"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...path]" }
  ]
}
